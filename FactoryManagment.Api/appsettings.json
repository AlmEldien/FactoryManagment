{
  "ConnectionStrings": {
    "DefaultConnection": "Everyone should put connection strings in secrets.json to don't make any conflict"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "FactoryManagementAPI"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "The type of key is Base64-encoded string and should be stored in secrets.json",
    "ExpiryMinutes": 60,
    "Issuer": "FactoryManagementAPI",
    "Audience": "FactoryManagementClient",
    "RefreshTokenExpiryDays": 7
  }
}
